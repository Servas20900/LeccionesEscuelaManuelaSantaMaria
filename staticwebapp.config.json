{
  "navigationFallback": {
    "rewrite": "/",
    "exclude": ["/api/*", "/_next/*", "/favicon.ico", "/*.css", "/*.js", "/*.json", "/*.wasm"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/admin",
      "statusCode": 302
    }
  }
}
